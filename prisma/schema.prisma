generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?
  avatar       String?
  role      String   @default("member")
  status    String   @default("offline")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedTasks     Task[]       @relation("AssignedTo")
  createdTasks      Task[]       @relation("CreatedBy")
  comments          Comment[]
  messages          Message[]
  uploadedFiles     FileItem[]
  workspaceMembers  WorkspaceMember[]
  teamMembers       TeamMember[]
  wikiEdits         WikiPage[]
  channelMemberships ChannelMember[]
  meetingMemberships MeetingMember[]
  ownedRisks        Risk[]          @relation("RiskOwner")
  timeEntries       TimeEntry[]
  changeRequests    ChangeRequest[] @relation("CRRequestedBy")
  weeklyCapacity    Float           @default(40)
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  color       String   @default("#10b981")
  icon        String   @default("🏢")
  logo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members        WorkspaceMember[]
  projects       Project[]
  channels       Channel[]
  teams          Team[]
  automations    Automation[]
  files          FileItem[]
  wikiPages      WikiPage[]
  activityLogs     ActivityLog[]
  documentChunks   DocumentChunk[]
  aiPendingActions AiPendingAction[]
}

model AiPendingAction {
  id          String   @id @default(uuid()) @db.Uuid
  toolName    String
  args        Json
  workspaceId String
  userId      String?
  preview     Json
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([expiresAt])
}

/// RAG document chunks — embedding column managed via raw SQL (pgvector vector(1024))
model DocumentChunk {
  id          String   @id @default(cuid())
  workspaceId String
  sourceType  String
  sourceId    String
  title       String
  content     String
  chunkIndex  Int
  contentHash String
  embedding   Unsupported("vector(1024)")
  metadata    Json     @default("{}")
  indexedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId, chunkIndex])
  @@index([workspaceId])
  @@map("DocumentChunk")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        String   @default("member")
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#10b981")
  icon        String   @default("📋")
  status      String   @default("active")
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ─── PMP: Cost Management ───
  budget       Float     @default(0)
  currency     String    @default("EUR")
  hourlyRate   Float     @default(50)
  startDate    DateTime?
  endDate      DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]
  meetings  Meeting[]

  risks          Risk[]
  stakeholders   Stakeholder[]
  baselines      Baseline[]
  changeRequests ChangeRequest[]
  timeEntries    TimeEntry[]
  sprints        Sprint[]
  milestones     Milestone[]

  @@index([workspaceId])
}

model Sprint {
  id        String    @id @default(cuid())
  name      String
  projectId String
  status    String    @default("planning")
  startDate DateTime?
  endDate   DateTime?
  goal      String?
  velocity  Int?
  createdAt DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
}

model Milestone {
  id          String    @id @default(cuid())
  title       String
  description String?
  projectId   String
  dueDate     DateTime?
  status      String    @default("upcoming")
  color       String    @default("#10b981")
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("medium")
  tags        String    @default("")
  dueDate     DateTime?
  projectId   String
  assigneeId  String?
  creatorId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ─── PMP: Schedule & Cost ───
  startDate      DateTime?
  estimatedHours Float     @default(0)
  sprintId       String?
  milestoneId    String?

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint    Sprint?  @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  milestone Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  assignee  User?    @relation("AssignedTo", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator   User?    @relation("CreatedBy", fields: [creatorId], references: [id], onDelete: SetNull)
  subtasks  Subtask[]
  comments  Comment[]

  predecessors TaskDependency[] @relation("SuccessorTask")
  successors   TaskDependency[] @relation("PredecessorTask")
  timeEntries  TimeEntry[]

  @@index([projectId])
  @@index([assigneeId])
}

// ═══════════════════════════════════════════════════════════
// PMP MODULES — Schedule, Cost, Risk, Stakeholders, Change
// ═══════════════════════════════════════════════════════════

// Task dependency (FS, SS, FF, SF) with optional lag — basis for critical path
model TaskDependency {
  id            String @id @default(cuid())
  predecessorId String
  successorId   String
  type          String @default("FS") // FS | SS | FF | SF
  lagDays       Int    @default(0)

  predecessor Task @relation("PredecessorTask", fields: [predecessorId], references: [id], onDelete: Cascade)
  successor   Task @relation("SuccessorTask", fields: [successorId], references: [id], onDelete: Cascade)

  @@unique([predecessorId, successorId])
  @@index([successorId])
}

// Time entries — actual cost (AC) source for EVM
model TimeEntry {
  id          String   @id @default(cuid())
  taskId      String
  projectId   String
  userId      String?
  date        DateTime @default(now())
  hours       Float
  description String?
  billable    Boolean  @default(true)
  hourlyRate  Float    @default(0)
  createdAt   DateTime @default(now())

  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([projectId])
  @@index([userId])
}

// Risk register (probability x impact, response strategy)
model Risk {
  id             String   @id @default(cuid())
  title          String
  description    String?
  category       String   @default("technical") // technical | external | organizational | project_management
  probability    Int      @default(3) // 1-5
  impact         Int      @default(3) // 1-5
  status         String   @default("open") // open | mitigating | closed | occurred
  response       String   @default("mitigate") // avoid | mitigate | transfer | accept
  mitigationPlan String?
  taskIds        String   @default("") // comma-separated task ids linked to this risk
  ownerId        String?
  projectId      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner   User?   @relation("RiskOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([projectId])
}

// Stakeholder register (influence/interest matrix, engagement level)
model Stakeholder {
  id           String   @id @default(cuid())
  name         String
  organization String?
  role         String?
  email        String?
  phone        String?
  website      String?
  logo         String?
  influence    Int      @default(3) // 1-5
  interest     Int      @default(3) // 1-5
  engagement   String   @default("neutral") // unaware | resistant | neutral | supportive | leading
  strategy     String?
  projectId    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// Project baselines (scope / schedule / cost snapshots)
model Baseline {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("integrated") // scope | schedule | cost | integrated
  snapshot  String // JSON snapshot of project state at creation time
  projectId String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// Change requests (scope change management)
model ChangeRequest {
  id             String    @id @default(cuid())
  title          String
  description    String?
  priority       String    @default("medium") // low | medium | high | urgent
  status         String    @default("pending") // pending | approved | rejected | implemented
  impactScope    String?
  impactDays     Int       @default(0)
  impactCost     Float     @default(0)
  decision       String?
  decidedAt      DateTime?
  requestedById  String?
  projectId      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy User?   @relation("CRRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([projectId])
}

model Subtask {
  id        String  @id @default(cuid())
  title     String
  completed Boolean @default(false)
  taskId    String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Channel {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("team")
  workspaceId String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages   Message[]
  channelMembers ChannelMember[]

  @@index([workspaceId])
}

model ChannelMember {
  id        String @id @default(cuid())
  channelId String
  userId    String

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  channelId String
  userId    String
  createdAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@index([userId])
}

model Meeting {
  id          String    @id @default(cuid())
  title       String
  description String?
  date        DateTime
  duration    Int       @default(60)
  status      String    @default("scheduled")
  link        String?
  projectId   String?
  createdAt   DateTime  @default(now())

  project        Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  meetingMembers MeetingMember[]

  @@index([projectId])
}

model MeetingMember {
  id        String @id @default(cuid())
  meetingId String
  userId    String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#10b981")
  workspaceId String
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  teamMembers TeamMember[]

  @@index([workspaceId])
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Automation {
  id          String    @id @default(cuid())
  name        String
  trigger     String
  action      String
  enabled     Boolean   @default(true)
  lastRun     DateTime?
  runCount    Int       @default(0)
  workspaceId String
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model FileItem {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("other")
  size        Int      @default(0)
  url         String
  projectId   String?
  workspaceId String
  uploadedBy  String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploader  User?     @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model WikiPage {
  id           String   @id @default(cuid())
  title        String
  content      String   @default("")
  icon         String   @default("📄")
  parentId     String?
  workspaceId  String
  lastEditedBy String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  editor    User?     @relation(fields: [lastEditedBy], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  type        String
  userId      String
  description String
  targetId    String?
  targetType  String?
  workspaceId String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
}
