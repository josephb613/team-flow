# PostgreSQL (e.g. Neon) - required
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Neon Auth - required for authentication (provision via Neon Console or MCP)
# Auth URL from Neon Console -> Branch -> Auth -> Configuration
NEON_AUTH_BASE_URL=https://your-project-id.neonauth.region.aws.neon.tech/neondb/auth
NEON_AUTH_COOKIE_SECRET=your-cookie-secret-at-least-32-characters

# Public app URL - used for password-reset redirect allowlist (set on Render)
# APP_URL=https://team-flow-vsr5.onrender.com

# Groq chat - required for AI chat features
GROQ_API_KEY=

# Chat model settings (defaults match src/lib/ai/config.ts)
AI_CHAT_PROVIDER=groq
AI_CHAT_MODEL=openai/gpt-oss-120b

# NVIDIA embeddings - required for semantic search / RAG indexing
NVIDIA_API_KEY=

# Embedding settings (optional; defaults in src/lib/ai/config.ts)
AI_EMBED_MODEL=nvidia/nv-embed-v1
AI_EMBED_BASE_URL=https://integrate.api.nvidia.com/v1
AI_EMBED_DIMENSIONS=1024
